{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "Digital Twin",
  "version": "0.1.0",
  "identifier": "com.digitaltwin.app",
  "build": {
    "frontendDist": "../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../web && npm run dev",
    "beforeBuildCommand": "cd ../web && npm run build"
  },
  "app": {
    "title": "Digital Twin 数字分身",
    "windows": [
      {
        "title": "Digital Twin",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
